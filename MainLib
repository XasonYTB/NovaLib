		local modal = Create("TextButton", {
			Name = "NovaModalButton",
			Parent = ScreenGui,
			Size = UDim2.fromScale(1, 1),
			BackgroundColor3 = Color3.fromRGB(0, 0, 0),
			BackgroundTransparency = 1,
			Text = "",
			Modal = true,
			Active = true,
			AutoButtonColor = false,
			ZIndex = 999998
		})
		window.ModalButton = modal
	end

	function window:GetConfigPath(name)
		local base = SafeName(name or window.ConfigBaseName)
		return string.format("%s/%s.json", window.ConfigFolder, base)
	end

	function window:CollectConfig()
		local data = {
			Theme = {
				Background = ColorToArray(window.Theme.Background),
				Surface = ColorToArray(window.Theme.Surface),
				Surface2 = ColorToArray(window.Theme.Surface2),
				Surface3 = ColorToArray(window.Theme.Surface3),
				Sidebar = ColorToArray(window.Theme.Sidebar),
				Accent = ColorToArray(window.Theme.Accent),
				Text = ColorToArray(window.Theme.Text),
				SubText = ColorToArray(window.Theme.SubText),
				Stroke = ColorToArray(window.Theme.Stroke),
				Cursor = ColorToArray(window.Theme.Cursor),
			},
			Values = {}
		}

		for key, entry in pairs(window._registry) do
			if entry and entry.Get then
				local ok, value = pcall(entry.Get, entry)
				if ok then
					data.Values[key] = value
				end
			end
		end

		return data
	end

	function window:ApplyConfig(data)
		if type(data) ~= "table" then
			return
		end

		if data.Theme then
			for k, v in pairs(data.Theme) do
				if window.Theme[k] ~= nil then
					window.Theme[k] = ArrayToColor(v)
				end
			end
		end

		if data.Values then
			for key, value in pairs(data.Values) do
				local entry = window._registry[key]
				if entry and entry.Set then
					pcall(function()
						entry:Set(value)
					end)
				end
			end
		end

		window:RefreshTheme()
	end

	function window:SaveConfig(name)
		local path = window:GetConfigPath(name)
		local encoded = HttpService:JSONEncode(window:CollectConfig())
		writeFile(path, encoded)
		window:Notify({
			Title = "Config Saved",
			Content = "Saved to " .. path,
			Color = window.Theme.Success,
			Duration = 3
		})
	end

	function window:LoadConfig(name)
		local path = window:GetConfigPath(name)
		if not isFile(path) then
			window:Notify({
				Title = "Config",
				Content = "Config not found.",
				Color = window.Theme.Danger,
				Duration = 3
			})
			return
		end

		local raw = readFile(path)
		if not raw then return end

		local ok, decoded = pcall(function()
			return HttpService:JSONDecode(raw)
		end)

		if ok and decoded then
			window:ApplyConfig(decoded)
			window:Notify({
				Title = "Config Loaded",
				Content = "Loaded " .. path,
				Color = window.Theme.Accent,
				Duration = 3
			})
		end
	end

	function window:GetConfigs()
		local out = {}
		for _, file in ipairs(listFiles(window.ConfigFolder)) do
			local name = tostring(file):match("([^/\\]+)%.json$")
			if name then
				table.insert(out, name)
			end
		end
		table.sort(out)
		return out
	end

	function window:DeleteConfig(name)
		local path = window:GetConfigPath(name)
		deleteFile(path)
		window:Notify({
			Title = "Config Deleted",
			Content = "Deleted " .. path,
			Color = window.Theme.Warning,
			Duration = 3
		})
	end

	function window:_RegisterControl(flag, control)
		if flag then
			registerControl(flag, control)
		end
	end

