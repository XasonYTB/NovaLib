	addCorner(ModalBtn, UDim.new(1,0))
	addStroke(ModalBtn, Color3.fromRGB(30,30,30), 1, 0.4)

	ModalBtn.MouseEnter:Connect(function()
		tween(ModalBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0})
	end)
	ModalBtn.MouseLeave:Connect(function()
		tween(ModalBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0.15})
	end)

	--// drag
	do
		local dragging = false
		local dragStart, startPos

		local function begin(input)
			dragging = true
			dragStart = input.Position
			startPos = Root.Position
		end

		local function update(input)
			if not dragging then return end
			local delta = input.Position - dragStart
			Root.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end

		Topbar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				begin(input)
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				update(input)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	end

	--// top buttons behavior
	MinBtn.MouseButton1Click:Connect(function()
		self.Minimized = not self.Minimized
		if self.Minimized then
			tween(Root, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = UDim2.new(self.Size.X.Scale, self.Size.X.Offset, 0, 56)
			})
			Body.Visible = false
			MinBtn.Text = "+"
		else
			Body.Visible = true
			tween(Root, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = self.Size
			})
			MinBtn.Text = "—"
		end
	end)

	HideBtn.MouseButton1Click:Connect(function()
		self:SetVisible(not self.Visible)
	end)

	CloseBtn.MouseButton1Click:Connect(function()
		self:Destroy()
	end)

	--// keyboard toggle
	table.insert(self.ConnectionBag, UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if input.KeyCode == self.ToggleKey then
			self:SetVisible(not self.Visible)
		end
	end))

	--// cursor update
	table.insert(self.ConnectionBag, RunService.RenderStepped:Connect(function()
		if self.CursorEnabled and UserInputService.MouseEnabled then
			local pos = UserInputService:GetMouseLocation()
			CursorDot.Visible = self.Visible
			CursorDot.Position = UDim2.fromOffset(pos.X, pos.Y)
		else
			CursorDot.Visible = false
		end
	end))

	--// modal mouse unlock
	ModalBtn.MouseButton1Click:Connect(function()
		self.ModalEnabled = not self.ModalEnabled
		self:_applyModal()
		self:Notify({
			Title = "Mouse Mode",
			Content = self.ModalEnabled and "Mouse unlocked for first person." or "Mouse relocked.",
			Time = 2.4
		})
	end)

	--// Settings tab always exists
	self.SettingsTab = self:CreateTab("⚙ Settings", true)
	self:_buildSettingsPage()

	--// welcome
	self:Notify({
		Title = "Nova Loaded",
		Content = "Nova UI V2 initialized successfully.",
		Time = 3
	})

	return self
end

function Nova:_applyModal()
	if self.ModalEnabled then
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	else
		UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
	end
end

function Nova:SetVisible(bool)
	self.Visible = bool
	self.Root.Visible = bool
	self.ModalButton.Visible = bool
end

function Nova:SetTheme(themeNameOrTable)
	local newTheme
	if type(themeNameOrTable) == "string" then
		self.ThemeName = themeNameOrTable
		newTheme = deepCopy(Themes[themeNameOrTable] or Themes.Default)
	elseif type(themeNameOrTable) == "table" then
		newTheme = deepCopy(themeNameOrTable)
	end
	if not newTheme then return end

	self.Theme = newTheme

	-- Simple live apply to core frames
	self.Root.BackgroundColor3 = self.Theme.BG
	self.TitleLabel.TextColor3 = self.Theme.Text
	self.SubTitle.TextColor3 = self.Theme.SubText
	self.Sidebar.BackgroundColor3 = self.Theme.Card
	self.CursorDot.BackgroundColor3 = self.Theme.Cursor
	if self.CursorDot:FindFirstChild("Glow") then
		self.CursorDot.Glow.BackgroundColor3 = self.Theme.Cursor
	end
end

function Nova:GetAutoConfigName()
	return self.ConfigPrefix
end

function Nova:_getConfigPath(name)
	name = sanitizeFileName(name or self:GetAutoConfigName())
	return string.format("%s/%s.json", self.ConfigFolder, name)
end

function Nova:SaveConfig(name)
	if not hasFS then
		return false, "Filesystem functions unavailable."
	end

	local path = self:_getConfigPath(name)
	local data = {
		Title = self.Title,
		Theme = self.Theme,
		Flags = self.Flags
	}

	local ok, encoded = safeCall(HttpService.JSONEncode, HttpService, data)
	if not ok then
		return false, "Failed to encode config."
	end

	local wOk = pcall(function()
		writefile(path, encoded)
	end)

	if wOk then
		return true, path
	end

	return false, "Failed to write config."
end

function Nova:LoadConfig(name)
	if not hasFS then
		return false, "Filesystem functions unavailable."
	end

	local path = self:_getConfigPath(name)
	if not isfile(path) then
		return false, "Config not found."
	end

	local ok, raw = safeCall(readfile, path)
	if not ok then
		return false, "Failed reading config."
	end

	local dOk, decoded = safeCall(HttpService.JSONDecode, HttpService, raw)
	if not dOk or not decoded then
		return false, "Failed decoding config."
	end

	if decoded.Theme then
		self:SetTheme(decoded.Theme)
	end

	if decoded.Flags then
		for flag, value in pairs(decoded.Flags) do
			self.Flags[flag] = value
			local component = self.Components[flag]
			if component and component.Set then
				pcall(function()
					component:Set(value, true)
				end)
			end
		end
	end

	return true, "Loaded."
end

function Nova:GetConfigs()
	if not hasFS then
		return {}
	end
	local files = listfiles(self.ConfigFolder)
	local out = {}
	for _, file in ipairs(files) do
		local name = file:match("([^/\\]+)%.json$")
		if name then
			table.insert(out, name)
		end
	end
	table.sort(out)
	return out
end

function Nova:DeleteConfig(name)
	if not hasFS then
		return false, "Filesystem functions unavailable."
	end
	local path = self:_getConfigPath(name)
	if not isfile(path) then
		return false, "Config not found."
	end
	local ok = pcall(function()
		delfile(path)
	end)
	return ok, ok and "Deleted." or "Failed."
end

