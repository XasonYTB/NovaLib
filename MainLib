local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

local NovaLib = {
    Flags = {}, -- Stores all toggle/slider states
    ConfigName = "NovaConfig.json",
    Theme = {
        MainBG = Color3.fromRGB(12, 12, 18),
        ElementBG = Color3.fromRGB(20, 20, 28),
        Accent = Color3.fromRGB(138, 43, 226), -- Purple Neon Glow
        Text = Color3.fromRGB(240, 240, 240)
    }
}

-- [ INTERNAL HELPERS ] --
local function create(className, properties)
    local inst = Instance.new(className)
    for k, v in pairs(properties) do
        inst[k] = v
    end
    return inst
end

-- [ PUBLIC API: WINDOW CREATION ] --
function NovaLib:CreateWindow(config)
    local title = config.Title or "Nova UI"
    
    -- Main GUI setup
    local screenGui = create("ScreenGui", {
        Name = "NovaInterface",
        Parent = (gethui and gethui()) or CoreGui, -- Supports exploit envs or standard studio
        ResetOnSpawn = false
    })

    local mainFrame = create("Frame", {
        Name = "Main",
        Parent = screenGui,
        Size = UDim2.new(0, 500, 0, 350),
        Position = UDim2.new(0.5, -250, 0.5, -175),
        BackgroundColor3 = self.Theme.MainBG,
        BorderSizePixel = 0,
        ClipsDescendants = true
    })
    
    -- Rounded Corners & Neon Stroke (The "Unique" Look)
    create("UICorner", { CornerRadius = UDim.new(0, 8), Parent = mainFrame })
    create("UIStroke", { 
        Color = self.Theme.Accent, 
        Thickness = 1.5, 
        Transparency = 0.4, 
        Parent = mainFrame 
    })

    local WindowAPI = {
        Container = mainFrame,
        Tabs = {}
    }

    -- [ PUBLIC API: TAB CREATION ] --
    function WindowAPI:CreateTab(tabName)
        local tabLayout = create("ScrollingFrame", {
            Name = tabName,
            Parent = mainFrame,
            Size = UDim2.new(1, -20, 1, -40),
            Position = UDim2.new(0, 10, 0, 30),
            BackgroundTransparency = 1,
            ScrollBarThickness = 2
        })
        
        create("UIListLayout", {
            Parent = tabLayout,
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 8)
        })

        local TabAPI = {}

        -- [ PUBLIC API: BUTTON CREATION ] --
        function TabAPI:CreateButton(btnConfig)
            local btn = create("TextButton", {
                Parent = tabLayout,
                Size = UDim2.new(1, 0, 0, 35),
                BackgroundColor3 = NovaLib.Theme.ElementBG,
                Text = "  " .. btnConfig.Name,
                TextColor3 = NovaLib.Theme.Text,
                Font = Enum.Font.GothamSemibold,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = btn })

            btn.MouseButton1Click:Connect(function()
                -- Button animation
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = NovaLib.Theme.Accent}):Play()
                task.wait(0.1)
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = NovaLib.Theme.ElementBG}):Play()
                
                if btnConfig.Callback then btnConfig.Callback() end
            end)
        end

        -- [ PUBLIC API: TOGGLE CREATION ] --
        function TabAPI:CreateToggle(tglConfig)
            local state = tglConfig.Default or false
            NovaLib.Flags[tglConfig.Flag] = state -- Register to saving system

            local toggleBtn = create("TextButton", {
                Parent = tabLayout,
                Size = UDim2.new(1, 0, 0, 35),
                BackgroundColor3 = NovaLib.Theme.ElementBG,
                Text = "  " .. tglConfig.Name,
                TextColor3 = NovaLib.Theme.Text,
                Font = Enum.Font.GothamSemibold,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = toggleBtn })

            -- Indicator graphic
            local indicator = create("Frame", {
                Parent = toggleBtn,
                Size = UDim2.new(0, 20, 0, 20),
                Position = UDim2.new(1, -30, 0.5, -10),
                BackgroundColor3 = state and NovaLib.Theme.Accent or Color3.fromRGB(40, 40, 50)
            })
            create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = indicator })

            local function updateToggle(newState)
                state = newState
                NovaLib.Flags[tglConfig.Flag] = state
                TweenService:Create(indicator, TweenInfo.new(0.2), {
                    BackgroundColor3 = state and NovaLib.Theme.Accent or Color3.fromRGB(40, 40, 50)
                }):Play()
                if tglConfig.Callback then tglConfig.Callback(state) end
            end

            toggleBtn.MouseButton1Click:Connect(function()
                updateToggle(not state)
            end)
        end

        return TabAPI
    end

    return WindowAPI
end

-- [ SAVING / CONFIG SYSTEM ] --
function NovaLib:SaveConfig()
    local success, json = pcall(function()
        return HttpService:JSONEncode(self.Flags)
    end)
    if success and writefile then
        writefile(self.ConfigName, json)
        print("Config Saved!")
    end
end

function NovaLib:LoadConfig()
    if readfile and isfile and isfile(self.ConfigName) then
        local success, json = pcall(function()
            return HttpService:JSONDecode(readfile(self.ConfigName))
        end)
        if success then
            for flag, value in pairs(json) do
                self.Flags[flag] = value
                -- Note: In a fully fleshed-out lib, you'd trigger the UI updates here too.
            end
            print("Config Loaded!")
        end
    end
end

return NovaLib
