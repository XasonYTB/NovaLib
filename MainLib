					TextSize = 13,
					TextColor3 = self.Tab.Window.Theme.Text,
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Frame
				})

				local Box = create("TextBox", {
					BackgroundColor3 = self.Tab.Window.Theme.Surface2,
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, -10, 0.5, 0),
					Size = UDim2.new(0.55, 0, 0, 28),
					Text = value,
					PlaceholderText = opts.Placeholder or "",
					ClearTextOnFocus = false,
					Font = Enum.Font.Gotham,
					TextSize = 12,
					TextColor3 = self.Tab.Window.Theme.Text,
					PlaceholderColor3 = self.Tab.Window.Theme.SubText,
					Parent = Frame
				})
				addCorner(Box, 8)
				addStroke(Box, self.Tab.Window.Theme.Border, 1, 0.35)

				Box.FocusLost:Connect(function(enterPressed)
					value = Box.Text
					pcall(callback, value, enterPressed)
				end)

				control.Frame = Frame
				control.Box = Box
				control.Label = Label
				control.Interactive = Box

				function control:Set(text, skipCallback)
					value = tostring(text)
					Box.Text = value
					if not skipCallback then
						pcall(callback, value, false)
					end
				end

				function control:Get()
					return value
				end

				function control:SetText(text)
					Label.Text = tostring(text)
				end

				function control:SetCallback(fn)
					callback = fn or function() end
				end

				registerConfig(key, function()
					return value
				end, function(v)
					control:Set(v, true)
				end)

				table.insert(Section.Controls, control)
				table.insert(self.Tab.Window.RuntimeRegistry, control)
				return control
			end

			-- Dropdown
			function Section:CreateDropdown(opts)
				opts = opts or {}
				local control = baseMethods(newControl("Dropdown"))

				local list = opts.Options or opts.List or {}
				local value = opts.Default or list[1] or ""
				local key = opts.Flag or opts.Key or opts.Name
				local callback = opts.Callback or function() end
				local open = false

				local Frame = create("Frame", {
					BackgroundColor3 = self.Tab.Window.Theme.Surface,
					Size = UDim2.new(1, 0, 0, 44),
					ClipsDescendants = true,
					Parent = Holder
				})
				addCorner(Frame, 10)
				addStroke(Frame, self.Tab.Window.Theme.Border, 1, 0.25)

				local MainBtn = create("TextButton", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 44),
					Text = "",
					Parent = Frame
				})

				local Label = create("TextLabel", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0, 0),
					Size = UDim2.new(0.4, 0, 0, 44),
					Text = opts.Name or "Dropdown",
					Font = Enum.Font.GothamMedium,
					TextSize = 13,
					TextColor3 = self.Tab.Window.Theme.Text,
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Frame
				})

				local Selected = create("TextLabel", {
					BackgroundTransparency = 1,
					AnchorPoint = Vector2.new(1, 0),
					Position = UDim2.new(1, -28, 0, 0),
					Size = UDim2.new(0.45, 0, 0, 44),
					Text = tostring(value),
					Font = Enum.Font.Gotham,
					TextSize = 12,
					TextColor3 = self.Tab.Window.Theme.SubText,
					TextXAlignment = Enum.TextXAlignment.Right,
					Parent = Frame
				})

				local Arrow = create("TextLabel", {
					BackgroundTransparency = 1,
					AnchorPoint = Vector2.new(1, 0),
					Position = UDim2.new(1, -10, 0, 0),
					Size = UDim2.new(0, 14, 0, 44),
					Text = "▾",
					Font = Enum.Font.GothamBold,
					TextSize = 14,
					TextColor3 = self.Tab.Window.Theme.SubText,
					Parent = Frame
				})

				local ListHolder = create("Frame", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 0, 0, 44),
					Size = UDim2.new(1, 0, 0, 0),
					Parent = Frame
				})

				local ListLayout = addListLayout(ListHolder, 6)
				addPadding(ListHolder, 10, 10, 4, 10)

				local buttons = {}

				local function rebuild()
					for _, b in ipairs(buttons) do
						b:Destroy()
					end
					table.clear(buttons)

					for _, item in ipairs(list) do
						local btn = create("TextButton", {
							BackgroundColor3 = self.Tab.Window.Theme.Surface2,
							Size = UDim2.new(1, 0, 0, 28),
							Text = tostring(item),
							Font = Enum.Font.Gotham,
							TextSize = 12,
							TextColor3 = self.Tab.Window.Theme.Text,
							AutoButtonColor = false,
							Parent = ListHolder
						})
						addCorner(btn, 8)
						addStroke(btn, self.Tab.Window.Theme.Border, 1, 0.35)
						applyButtonHover(btn, self.Tab.Window.Theme.Surface2, self.Tab.Window.Theme.Surface3)

						btn.MouseButton1Click:Connect(function()
							value = item
							Selected.Text = tostring(value)
							pcall(callback, value)
							open = false
							tween(Frame, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, 44)})
							Arrow.Text = "▾"
						end)

						table.insert(buttons, btn)
					end
				end

				local function getOpenSize()
					return 44 + (#list * 34) + 10
				end

				MainBtn.MouseButton1Click:Connect(function()
					if control.Locked then return end
					open = not open
					if open then
						rebuild()
						tween(Frame, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, getOpenSize())})
						Arrow.Text = "▴"
					else
						tween(Frame, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, 44)})
						Arrow.Text = "▾"
					end
				end)

				control.Frame = Frame
				control.Button = MainBtn
				control.Label = Label

				function control:Set(v, skipCallback)
					value = v
					Selected.Text = tostring(v)
					if not skipCallback then
						pcall(callback, value)
					end
				end

				function control:Get()
					return value
				end

				function control:SetText(text)
					Label.Text = tostring(text)
				end

				function control:SetOptions(newList)
					list = newList or {}
					if open then
						rebuild()
						tween(Frame, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, getOpenSize())})
					end
				end

				function control:SetCallback(fn)
					callback = fn or function() end
				end

				registerConfig(key, function()
					return value
				end, function(v)
					control:Set(v, true)
				end)

				table.insert(Section.Controls, control)
				table.insert(self.Tab.Window.RuntimeRegistry, control)
				return control
			end

			-- Keybind
			function Section:CreateKeybind(opts)
				opts = opts or {}
				local control = baseMethods(newControl("Keybind"))

				local key = opts.Default or Enum.KeyCode.F
				local waiting = false
				local callback = opts.Callback or function() end
				local configKey = opts.Flag or opts.Key or opts.Name

				local Frame = create("Frame", {
					BackgroundColor3 = self.Tab.Window.Theme.Surface,
					Size = UDim2.new(1, 0, 0, 44),
					Parent = Holder
				})
				addCorner(Frame, 10)
				addStroke(Frame, self.Tab.Window.Theme.Border, 1, 0.25)

				local Label = create("TextLabel", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0, 0),
					Size = UDim2.new(0.5, 0, 1, 0),
					Text = opts.Name or "Keybind",
					Font = Enum.Font.GothamMedium,
					TextSize = 13,
					TextColor3 = self.Tab.Window.Theme.Text,
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Frame
				})

				local BindBtn = create("TextButton", {
					BackgroundColor3 = self.Tab.Window.Theme.Surface2,
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, -10, 0.5, 0),
					Size = UDim2.new(0, 100, 0, 28),
					Text = key.Name,
					Font = Enum.Font.Gotham,
					TextSize = 12,
					TextColor3 = self.Tab.Window.Theme.Text,
					AutoButtonColor = false,
					Parent = Frame
				})
				addCorner(BindBtn, 8)
				addStroke(BindBtn, self.Tab.Window.Theme.Border, 1, 0.35)

				BindBtn.MouseButton1Click:Connect(function()
					if control.Locked then return end
					waiting = true
					BindBtn.Text = "Press..."
				end)

				UserInputService.InputBegan:Connect(function(input, gpe)
					if gpe then return end

					if waiting and input.KeyCode ~= Enum.KeyCode.Unknown then
						key = input.KeyCode
						BindBtn.Text = key.Name
						waiting = false
						return
					end

					if input.KeyCode == key then
						pcall(callback, key)
					end
				end)

				applyButtonHover(BindBtn, self.Tab.Window.Theme.Surface2, self.Tab.Window.Theme.Surface3)

				control.Frame = Frame
				control.Button = BindBtn
				control.Label = Label

				function control:Set(newKey)
					key = newKey
					BindBtn.Text = key.Name
				end

				function control:Get()
					return key
				end

				function control:SetText(text)
					Label.Text = tostring(text)
				end

				function control:SetCallback(fn)
					callback = fn or function() end
				end

				registerConfig(configKey, function()
					return key.Name
				end, function(v)
					local kc = Enum.KeyCode[v]
					if kc then
						control:Set(kc)
					end
				end)

				table.insert(Section.Controls, control)
				table.insert(self.Tab.Window.RuntimeRegistry, control)
				return control
			end

			table.insert(self.Sections, Section)
			return Section
		end

		Tab.Button = TabBtn
		Tab.Page = Page
		table.insert(self.Tabs, Tab)

		if #self.Tabs == 1 then
			Tab:SetActive(true)
		end

		return Tab
	end

	--// Built-in Settings Tab
	function Window:BuildSettingsTab()
		if self.SettingsBuilt then return end
		self.SettingsBuilt = true

		local Settings = self:CreateTab("Settings", "⚙")

		local Appearance = Settings:CreateSection("Appearance")
		local Configs = Settings:CreateSection("Configs")
		local Controls = Settings:CreateSection("Controls")

		Appearance:CreateLabel({Text = "Nova UI Library V" .. Nova.Version})

		local AccentR = Appearance:CreateSlider({
			Name = "Accent Red",
			Min = 0,
			Max = 255,
			Default = math.floor(self.Theme.Accent.R * 255),
			Callback = function(v)
				local c = Color3.fromRGB(
					v,
					math.floor(self.Theme.Accent.G * 255),
					math.floor(self.Theme.Accent.B * 255)
				)
				self:SetAccent(c)
			end
		})

		local AccentG = Appearance:CreateSlider({
			Name = "Accent Green",
			Min = 0,
			Max = 255,
			Default = math.floor(self.Theme.Accent.G * 255),
			Callback = function(v)
				local c = Color3.fromRGB(
					math.floor(self.Theme.Accent.R * 255),
					v,
					math.floor(self.Theme.Accent.B * 255)
				)
				self:SetAccent(c)
			end
		})

		local AccentB = Appearance:CreateSlider({
			Name = "Accent Blue",
			Min = 0,
			Max = 255,
			Default = math.floor(self.Theme.Accent.B * 255),
			Callback = function(v)
				local c = Color3.fromRGB(
					math.floor(self.Theme.Accent.R * 255),
					math.floor(self.Theme.Accent.G * 255),
					v
				)
				self:SetAccent(c)
			end
		})

		Appearance:CreateSeparator("Cursor")

		local CursorToggle = Appearance:CreateToggle({
			Name = "Custom Dot Cursor",
			Default = self.CustomCursorEnabled,
			Callback = function(v)
				self:SetCursorEnabled(v)
			end
		})

		local CursorR = Appearance:CreateSlider({
			Name = "Cursor Red",
			Min = 0,
			Max = 255,
			Default = math.floor(self.Theme.Cursor.R * 255),
			Callback = function(v)
				self:SetCursorColor(Color3.fromRGB(
					v,
					math.floor(self.Theme.Cursor.G * 255),
					math.floor(self.Theme.Cursor.B * 255)
				))
			end
		})

		local CursorG = Appearance:CreateSlider({
			Name = "Cursor Green",
			Min = 0,
			Max = 255,
			Default = math.floor(self.Theme.Cursor.G * 255),
			Callback = function(v)
				self:SetCursorColor(Color3.fromRGB(
					math.floor(self.Theme.Cursor.R * 255),
					v,
					math.floor(self.Theme.Cursor.B * 255)
				))
			end
		})

		local CursorB = Appearance:CreateSlider({
			Name = "Cursor Blue",
			Min = 0,
			Max = 255,
			Default = math.floor(self.Theme.Cursor.B * 255),
			Callback = function(v)
				self:SetCursorColor(Color3.fromRGB(
					math.floor(self.Theme.Cursor.R * 255),
					math.floor(self.Theme.Cursor.G * 255),
					v
				))
			end
		})

		local ConfigName = Configs:CreateTextbox({
			Name = "Config Name",
			Default = self.DefaultConfigName
		})

		local ConfigListLabel = Configs:CreateParagraph({
			Text = "Saved configs will appear here after refresh."
		})

		local function refreshConfigList()
			local list = self:GetConfigs()
			if #list == 0 then
				ConfigListLabel:SetText("No saved configs found.")
			else
				ConfigListLabel:SetText("Saved Configs:\n- " .. table.concat(list, "\n- "))
			end
		end

		Configs:CreateButton({
			Name = "Save Config",
			Callback = function()
				self:SaveConfig(ConfigName:Get())
				refreshConfigList()
			end
		})

		Configs:CreateButton({
			Name = "Load Config",
			Callback = function()
				self:LoadConfig(ConfigName:Get())
			end
		})

		Configs:CreateButton({
			Name = "Delete Config",
			Callback = function()
				self:DeleteConfig(ConfigName:Get())
				refreshConfigList()
			end
		})

		Configs:CreateButton({
			Name = "Refresh Config List",
			Callback = function()
				refreshConfigList()
			end
		})

		refreshConfigList()

		Controls:CreateKeybind({
			Name = "UI Toggle Key",
			Default = self.ToggleKeybind,
			Callback = function() end
		})

		Controls:CreateButton({
			Name = "Toggle Modal Mouse",
			Callback = function()
				self:SetModalEnabled(not modalEnabled)
			end
		})

		Controls:CreateButton({
			Name = "Minimize Window",
			Callback = function()
				self:SetMinimized(not self.IsMinimized)
			end
		})

		Controls:CreateButton({
			Name = "Hide / Show Window",
			Callback = function()
				self:ToggleVisible()
			end
		})
	end

	Window:BuildSettingsTab()

	--// Convenience
	function Window:CreateTab(...)
		return getmetatable(self).CreateTab(self, ...)
	end

	table.insert(Nova.Windows, Window)

	Window:Notify({
		Title = "Nova UI",
		Content = "Loaded " .. Window.Title .. " successfully.",
		Color = Window.Theme.Accent
	})

	return Window
end

return Nova
