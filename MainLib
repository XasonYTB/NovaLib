--// Utility for mobile detection
local function isMobile()
	return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

--// Base Control Class
local function newControl(controlType)
	local self = {
		Type = controlType,
		Destroyed = false,
		Visible = true,
		Locked = false,
		Connections = {},
	}
	return self
end

local function connect(control, signal, callback)
	local c = signal:Connect(callback)
	table.insert(control.Connections, c)
	return c
end

local function cleanupControl(control)
	for _, c in ipairs(control.Connections) do
		pcall(function()
			c:Disconnect()
		end)
	end
	control.Connections = {}
	control.Destroyed = true
	if control.Frame then
		control.Frame:Destroy()
	end
end

--// Theme application helpers
local function applyButtonHover(btn, baseColor, hoverColor)
	btn.MouseEnter:Connect(function()
		tween(btn, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundColor3 = hoverColor
		})
	end)
	btn.MouseLeave:Connect(function()
		tween(btn, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundColor3 = baseColor
		})
	end)
end

