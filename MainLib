					Font = Enum.Font.GothamMedium,
					TextSize = 13,
					TextColor3 = window.Theme.Text,
					TextXAlignment = Enum.TextXAlignment.Left
				})

				local valueLbl = Create("TextLabel", {
					Parent = f,
					BackgroundTransparency = 1,
					AnchorPoint = Vector2.new(1, 0),
					Position = UDim2.new(1, -12, 0, 8),
					Size = UDim2.new(0, 60, 0, 16),
					Text = tostring(value),
					Font = Enum.Font.Gotham,
					TextSize = 12,
					TextColor3 = window.Theme.SubText,
					TextXAlignment = Enum.TextXAlignment.Right
				})

				local bar = Create("Frame", {
					Parent = f,
					Position = UDim2.new(0, 12, 0, 34),
					Size = UDim2.new(1, -24, 0, 8),
					BackgroundColor3 = window.Theme.Surface,
					BorderSizePixel = 0
				})
				Corner(bar, 8)

				local fill = Create("Frame", {
					Parent = bar,
					Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
					BackgroundColor3 = window.Theme.Accent,
					BorderSizePixel = 0
				})
				Corner(fill, 8)

				local knob = Create("Frame", {
					Parent = bar,
					AnchorPoint = Vector2.new(0.5, 0.5),
					Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
					Size = UDim2.new(0, 14, 0, 14),
					BackgroundColor3 = window.Theme.Text,
					BorderSizePixel = 0
				})
				Corner(knob, 14)

				local function set(v, skip)
					value = math.clamp(v, min, max)
					local pct = (value - min) / (max - min)
					fill.Size = UDim2.new(pct, 0, 1, 0)
					knob.Position = UDim2.new(pct, 0, 0.5, 0)
					local display = decimals > 0 and string.format("%." .. tostring(decimals) .. "f", value) or tostring(math.floor(value + 0.5))
					valueLbl.Text = display
					if not skip then
						safeCall(callback, value)
					end
				end

				local function setFromX(x)
					local pct = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
					local raw = min + ((max - min) * pct)
					value = decimals > 0 and raw or math.floor(raw + 0.5)
					set(value)
				end

				bar.InputBegan:Connect(function(input)
					if control.Locked then return end
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = true
						setFromX(input.Position.X)
					end
				end)

				trackConnection(UserInputService.InputChanged:Connect(function(input)
					if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						setFromX(input.Position.X)
					end
				end))

				trackConnection(UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = false
					end
				end))

				control.Frame = f
				control.Bar = bar
				control.Fill = fill
				control.Label = lbl
				control.ValueLabel = valueLbl
				control.Interactive = bar
				function control:Set(v, skip)
					set(v, skip)
				end
				function control:Get()
					return value
				end
				function control:SetText(text)
					lbl.Text = tostring(text)
				end
				function control:SetCallback(fn)
					callback = fn or function() end
				end
				function control:UpdateTheme()
					fill.BackgroundColor3 = window.Theme.Accent
				end

				window:_RegisterControl(key, control)
				table.insert(section.Controls, control)
				return control
			end

