local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local NovaV2 = {
    Flags = {},
    Theme = {
        Background = Color3.fromRGB(15, 15, 15),
        GroupBoxBG = Color3.fromRGB(20, 20, 20),
        ElementBG = Color3.fromRGB(25, 25, 25),
        Outline = Color3.fromRGB(40, 40, 40),
        Accent = Color3.fromRGB(105, 105, 255), -- Crisp Blue Accent
        Text = Color3.fromRGB(220, 220, 220),
        TextDark = Color3.fromRGB(150, 150, 150)
    }
}

-- [ HELPER ] --
local function create(className, properties)
    local inst = Instance.new(className)
    for k, v in pairs(properties) do inst[k] = v end
    return inst
end

-- [ PUBLIC API: WINDOW ] --
function NovaV2:CreateWindow(title)
    local screenGui = create("ScreenGui", {
        Name = "NovaV2",
        Parent = (gethui and gethui()) or CoreGui,
        ResetOnSpawn = false
    })

    local mainFrame = create("Frame", {
        Size = UDim2.new(0, 600, 0, 450),
        Position = UDim2.new(0.5, -300, 0.5, -225),
        BackgroundColor3 = self.Theme.Background,
        BorderSizePixel = 0,
        Parent = screenGui
    })
    
    -- Linoria-style crisp outline
    create("UIStroke", {Color = self.Theme.Outline, Thickness = 1, Parent = mainFrame})

    local topBar = create("Frame", {
        Size = UDim2.new(1, 0, 0, 25),
        BackgroundColor3 = self.Theme.GroupBoxBG,
        BorderSizePixel = 0,
        Parent = mainFrame
    })
    create("UIStroke", {Color = self.Theme.Outline, Thickness = 1, Parent = topBar})

    local titleText = create("TextLabel", {
        Size = UDim2.new(1, -10, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = self.Theme.Text,
        Font = Enum.Font.Code,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = topBar
    })

    local tabContainer = create("Frame", {
        Size = UDim2.new(1, -10, 1, -35),
        Position = UDim2.new(0, 5, 0, 30),
        BackgroundTransparency = 1,
        Parent = mainFrame
    })

    -- Simple Dragging Logic
    local dragging, dragInput, dragStart, startPos
    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    topBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    local WindowAPI = {}

    -- [ PUBLIC API: TABS & GROUPBOXES ] --
    function WindowAPI:CreateTab(name)
        local tabFrame = create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Parent = tabContainer
        })

        -- Left and Right Columns (The Linoria Layout)
        local leftSide = create("Frame", {
            Size = UDim2.new(0.5, -5, 1, 0),
            BackgroundTransparency = 1,
            Parent = tabFrame
        })
        create("UIListLayout", {Padding = UDim.new(0, 10), Parent = leftSide})

        local rightSide = create("Frame", {
            Size = UDim2.new(0.5, -5, 1, 0),
            Position = UDim2.new(0.5, 5, 0, 0),
            BackgroundTransparency = 1,
            Parent = tabFrame
        })
        create("UIListLayout", {Padding = UDim.new(0, 10), Parent = rightSide})

        local TabAPI = {}

        function TabAPI:CreateGroupbox(gbTitle, side)
            local targetSide = (side:lower() == "left") and leftSide or rightSide

            local groupFrame = create("Frame", {
                Size = UDim2.new(1, 0, 0, 20), -- Will auto-scale
                BackgroundColor3 = NovaV2.Theme.GroupBoxBG,
                BorderSizePixel = 0,
                Parent = targetSide
            })
            create("UIStroke", {Color = NovaV2.Theme.Outline, Thickness = 1, Parent = groupFrame})

            local gbLabel = create("TextLabel", {
                Size = UDim2.new(1, -10, 0, 20),
                Position = UDim2.new(0, 5, 0, 0),
                BackgroundTransparency = 1,
                Text = gbTitle,
                TextColor3 = NovaV2.Theme.Text,
                Font = Enum.Font.Code,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = groupFrame
            })

            local gbLayout = create("UIListLayout", {
                Padding = UDim.new(0, 5),
                SortOrder = Enum.SortOrder.LayoutOrder,
                Parent = groupFrame
            })
            
            -- Padding for elements
            create("UIPadding", {
                PaddingTop = UDim.new(0, 25),
                PaddingBottom = UDim.new(0, 5),
                PaddingLeft = UDim.new(0, 5),
                PaddingRight = UDim.new(0, 5),
                Parent = groupFrame
            })

            -- Auto-scale Groupbox based on elements inside
            gbLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                groupFrame.Size = UDim2.new(1, 0, 0, gbLayout.AbsoluteContentSize.Y + 30)
            end)

            local GroupAPI = {}

            -- [ ELEMENT: TOGGLE ] --
            function GroupAPI:AddToggle(config)
                local state = config.Default or false
                NovaV2.Flags[config.Flag] = state

                local tglFrame = create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 15),
                    BackgroundTransparency = 1,
                    Text = "",
                    Parent = groupFrame
                })

                local box = create("Frame", {
                    Size = UDim2.new(0, 12, 0, 12),
                    Position = UDim2.new(0, 0, 0.5, -6),
                    BackgroundColor3 = state and NovaV2.Theme.Accent or NovaV2.Theme.ElementBG,
                    BorderSizePixel = 0,
                    Parent = tglFrame
                })
                create("UIStroke", {Color = NovaV2.Theme.Outline, Thickness = 1, Parent = box})

                create("TextLabel", {
                    Size = UDim2.new(1, -20, 1, 0),
                    Position = UDim2.new(0, 20, 0, 0),
                    BackgroundTransparency = 1,
                    Text = config.Name,
                    TextColor3 = NovaV2.Theme.TextDark,
                    Font = Enum.Font.Code,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = tglFrame
                })

                tglFrame.MouseButton1Click:Connect(function()
                    state = not state
                    NovaV2.Flags[config.Flag] = state
                    box.BackgroundColor3 = state and NovaV2.Theme.Accent or NovaV2.Theme.ElementBG
                    if config.Callback then config.Callback(state) end
                end)
            end

            -- [ ELEMENT: SLIDER ] --
            function GroupAPI:AddSlider(config)
                local value = config.Default or config.Min
                NovaV2.Flags[config.Flag] = value

                local sliderFrame = create("Frame", {
                    Size = UDim2.new(1, 0, 0, 35),
                    BackgroundTransparency = 1,
                    Parent = groupFrame
                })

                create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 15),
                    BackgroundTransparency = 1,
                    Text = config.Name,
                    TextColor3 = NovaV2.Theme.TextDark,
                    Font = Enum.Font.Code,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = sliderFrame
                })

                local valLabel = create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 15),
                    BackgroundTransparency = 1,
                    Text = tostring(value),
                    TextColor3 = NovaV2.Theme.Text,
                    Font = Enum.Font.Code,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Parent = sliderFrame
                })

                local barBG = create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 10),
                    Position = UDim2.new(0, 0, 0, 20),
                    BackgroundColor3 = NovaV2.Theme.ElementBG,
                    Text = "",
                    AutoButtonColor = false,
                    Parent = sliderFrame
                })
                create("UIStroke", {Color = NovaV2.Theme.Outline, Thickness = 1, Parent = barBG})

                local fill = create("Frame", {
                    Size = UDim2.new((value - config.Min) / (config.Max - config.Min), 0, 1, 0),
                    BackgroundColor3 = NovaV2.Theme.Accent,
                    BorderSizePixel = 0,
                    Parent = barBG
                })

                -- Sliding Logic
                local isSliding = false
                barBG.MouseButton1Down:Connect(function() isSliding = true end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then isSliding = false end
                end)

                RunService.RenderStepped:Connect(function()
                    if isSliding then
                        local mousePos = UserInputService:GetMouseLocation().X
                        local barPos = barBG.AbsolutePosition.X
                        local barSize = barBG.AbsoluteSize.X
                        local percent = math.clamp((mousePos - barPos) / barSize, 0, 1)
                        
                        value = math.floor(config.Min + ((config.Max - config.Min) * percent))
                        NovaV2.Flags[config.Flag] = value
                        fill.Size = UDim2.new(percent, 0, 1, 0)
                        valLabel.Text = tostring(value)
                        
                        if config.Callback then config.Callback(value) end
                    end
                end)
            end

            -- [ ELEMENT: DROPDOWN ] --
            function GroupAPI:AddDropdown(config)
                local selected = config.Default or config.Options[1]
                NovaV2.Flags[config.Flag] = selected

                local dropFrame = create("Frame", {
                    Size = UDim2.new(1, 0, 0, 45),
                    BackgroundTransparency = 1,
                    Parent = groupFrame
                })

                create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 15),
                    BackgroundTransparency = 1,
                    Text = config.Name,
                    TextColor3 = NovaV2.Theme.TextDark,
                    Font = Enum.Font.Code,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = dropFrame
                })

                local mainBtn = create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 20),
                    Position = UDim2.new(0, 0, 0, 20),
                    BackgroundColor3 = NovaV2.Theme.ElementBG,
                    Text = "  " .. tostring(selected),
                    TextColor3 = NovaV2.Theme.Text,
                    Font = Enum.Font.Code,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = dropFrame
                })
                create("UIStroke", {Color = NovaV2.Theme.Outline, Thickness = 1, Parent = mainBtn})
                
                -- Simple toggle behavior for dropdown list (mockup for brevity)
                mainBtn.MouseButton1Click:Connect(function()
                    mainBtn.Text = "  [Clicked! Expand Logic Here]" 
                    task.wait(0.5)
                    mainBtn.Text = "  " .. tostring(selected)
                    -- In a full version, this triggers a ScrollingFrame creation over the UI.
                end)
            end

            return GroupAPI
        end

        return TabAPI
    end

    return WindowAPI
end

return NovaV2
