		task.delay(opts.Duration or 4, function()
			if n and n.Parent then
				tween(n, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
					BackgroundTransparency = 1
				})
				task.wait(0.22)
				n:Destroy()
			end
		end)
	end

	--// Config helpers
	function Window:GetConfigPath(name)
		local finalName = safeName(name or self.DefaultConfigName)
		return string.format("%s/%s.json", self.ConfigFolder, finalName)
	end

	function Window:CollectConfigData()
		local data = {
			Theme = {
				Accent = {self.Theme.Accent.R, self.Theme.Accent.G, self.Theme.Accent.B},
				Cursor = {self.Theme.Cursor.R, self.Theme.Cursor.G, self.Theme.Cursor.B},
			},
			Values = {}
		}

		for key, info in pairs(self.ConfigValues) do
			data.Values[key] = info.Get()
		end

		return data
	end

	function Window:ApplyConfigData(data)
		if not data then return end

		if data.Theme then
			if data.Theme.Accent then
				local c = data.Theme.Accent
				self:SetAccent(Color3.new(c[1], c[2], c[3]))
			end
			if data.Theme.Cursor then
				local c = data.Theme.Cursor
				self:SetCursorColor(Color3.new(c[1], c[2], c[3]))
			end
		end

		if data.Values then
			for key, value in pairs(data.Values) do
				local info = self.ConfigValues[key]
				if info and info.Set then
					pcall(function()
						info.Set(value)
					end)
				end
			end
		end
	end

	function Window:SaveConfig(name)
		if not self.SaveConfigEnabled then
			self:Notify({
				Title = "Config",
				Content = "SaveConfig is disabled for this window.",
				Color = self.Theme.Warning
			})
			return
		end

		local path = self:GetConfigPath(name)
		local data = self:CollectConfigData()
		local encoded = HttpService:JSONEncode(data)
		writefileSafe(path, encoded)

		self:Notify({
			Title = "Config Saved",
			Content = "Saved config: " .. safeName(name or self.DefaultConfigName),
			Color = self.Theme.Success
		})
	end

	function Window:LoadConfig(name)
		local path = self:GetConfigPath(name)
		local content = readfileSafe(path)
		if not content then
			self:Notify({
				Title = "Config",
				Content = "Config not found.",
				Color = self.Theme.Danger
			})
			return
		end

		local ok, data = pcall(function()
			return HttpService:JSONDecode(content)
		end)

		if ok and data then
			self:ApplyConfigData(data)
			self:Notify({
				Title = "Config Loaded",
				Content = "Loaded config: " .. safeName(name or self.DefaultConfigName),
				Color = self.Theme.Accent
			})
		end
	end

	function Window:GetConfigs()
		local files = listfilesSafe(self.ConfigFolder)
		local out = {}

		for _, file in ipairs(files) do
			local name = tostring(file):match("([^/\\]+)%.json$")
			if name then
				table.insert(out, name)
			end
		end

		table.sort(out)
		return out
	end

	function Window:DeleteConfig(name)
		local path = self:GetConfigPath(name)
		delfileSafe(path)

