			BackgroundColor3 = window.Theme.Surface,
			BorderSizePixel = 0,
			ClipsDescendants = true
		})
		Corner(card, 12)
		Stroke(card, window.Theme.Stroke, 1, 0.2)

		local bar = Create("Frame", {
			Parent = card,
			Size = UDim2.new(0, 4, 1, 0),
			BackgroundColor3 = data.Color or window.Theme.Accent,
			BorderSizePixel = 0
		})

		local title = Create("TextLabel", {
			Parent = card,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 12, 0, 8),
			Size = UDim2.new(1, -24, 0, 18),
			Font = Enum.Font.GothamBold,
			Text = data.Title or "Notification",
			TextColor3 = window.Theme.Text,
			TextSize = 14,
			TextXAlignment = Enum.TextXAlignment.Left
		})

		local content = Create("TextLabel", {
			Parent = card,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 12, 0, 28),
			Size = UDim2.new(1, -24, 0, 34),
			Font = Enum.Font.Gotham,
			TextWrapped = true,
			Text = data.Content or "...",
			TextColor3 = window.Theme.SubText,
			TextSize = 12,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = Enum.TextYAlignment.Top
		})

		Tween(card, {Size = UDim2.new(1, 0, 0, 68)}, 0.18)

		task.delay(data.Duration or 4, function()
			if card and card.Parent then
				Tween(card, {Size = UDim2.new(1, 0, 0, 0)}, 0.18)
				task.wait(0.2)
				if card then
					card:Destroy()
				end
			end
		end)
	end

	function window:SetTheme(newTheme)
		for k, v in pairs(newTheme or {}) do
			if window.Theme[k] ~= nil then
				window.Theme[k] = v
			end
		end
		window:RefreshTheme()
	end

	function window:RefreshTheme()
		refreshWindowFrames()
		for _, tab in ipairs(window.Tabs) do
			if tab.ApplyTheme then
				pcall(tab.ApplyTheme)
			end
		end
		if window.CursorDot then
			window.CursorDot.BackgroundColor3 = window.Theme.Cursor
		end
		if window.ModalButton then
			window.ModalButton.TextColor3 = window.Theme.Text
		end
	end

	function window:SetVisibilityKey(key)
		window.ToggleKeybind = key
	end

	function window:SetCursor(cfg)
		cfg = cfg or {}
		window.CursorEnabled = cfg.Enabled ~= false
		window.Theme.Cursor = cfg.Color or window.Theme.Cursor
		window.CursorSize = cfg.Size or 6

		if window.CursorDot then
			window.CursorDot:Destroy()
			window.CursorDot = nil
		end

		if window.CursorRenderName then
			pcall(function()
				RunService:UnbindFromRenderStep(window.CursorRenderName)
			end)
			window.CursorRenderName = nil
		end

		if not window.CursorEnabled or window.Mobile then
			return
		end

		LocalPlayer:GetMouse().Icon = ""

		local dot = Create("Frame", {
			Name = "NovaCursor",
			Parent = ScreenGui,
			Size = UDim2.fromOffset(window.CursorSize, window.CursorSize),
			BackgroundColor3 = window.Theme.Cursor,
			BorderSizePixel = 0,
			AnchorPoint = Vector2.new(0.5, 0.5),
			ZIndex = 999999,
			BackgroundTransparency = 0
		})
		Corner(dot, 999)
		window.CursorDot = dot

		window.CursorRenderName = "NovaCursor_" .. SafeName(window.WindowTitleSafe .. "_" .. tostring(math.random(1000, 9999)))
		RunService:BindToRenderStep(window.CursorRenderName, Enum.RenderPriority.Last.Value, function()
			if not dot or not dot.Parent then return end
			dot.Position = UDim2.fromOffset(LocalPlayer:GetMouse().X, LocalPlayer:GetMouse().Y)
			dot.Visible = window.Visible and window.CursorEnabled and not window.Mobile
		end)
	end

