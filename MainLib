local function makeRipple(parent, x, y, color)
	local ripple = create("Frame", {
		BackgroundColor3 = color,
		BackgroundTransparency = 0.7,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromOffset(x, y),
		Size = UDim2.fromOffset(0, 0),
		ZIndex = parent.ZIndex + 10,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Parent = parent
	})
	addCorner(ripple, UDim.new(1,0))

	local max = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2
	tween(ripple, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.fromOffset(max, max),
		BackgroundTransparency = 1
	})
	task.delay(0.48, function()
		if ripple then ripple:Destroy() end
	end)
end

local function attachButtonFx(button, theme)
	local base = button.BackgroundColor3
	button.MouseEnter:Connect(function()
		tween(button, TweenInfo.new(0.15), {
			BackgroundColor3 = button.BackgroundColor3:Lerp(theme.Panel2, 0.35)
		})
	end)
	button.MouseLeave:Connect(function()
		tween(button, TweenInfo.new(0.15), {
			BackgroundColor3 = base
		})
	end)
	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			local pos = input.Position
			local abs = button.AbsolutePosition
			makeRipple(button, pos.X - abs.X, pos.Y - abs.Y, theme.Accent)
			tween(button, TweenInfo.new(0.08), {Size = button.Size - UDim2.fromOffset(0,0)})
		end
	end)
end

local function deepCopy(tbl)
	local copy = {}
	for k, v in pairs(tbl) do
		if type(v) == "table" then
			copy[k] = deepCopy(v)
		else
			copy[k] = v
		end
	end
	return copy
end

