				BorderSizePixel = 0,
				Parent = root
			})
			addCorner(box, UDim.new(1,0))
			addStroke(box, self.Tab.Window.Theme.Stroke, 1, 0)

			local knob = create("Frame", {
				Position = UDim2.fromOffset(2, 2),
				Size = UDim2.fromOffset(18, 18),
				BackgroundColor3 = self.Tab.Window.Theme.SubText,
				BorderSizePixel = 0,
				Parent = box
			})
			addCorner(knob, UDim.new(1,0))

			local comp = {Root = root, Value = state, Locked = false}

			local function render(skipCallback)
				comp.Value = state
				self.Tab.Window.Flags[flag] = state
				if state then
					tween(box, TweenInfo.new(0.18), {BackgroundColor3 = self.Tab.Window.Theme.Accent})
					tween(knob, TweenInfo.new(0.18), {
						Position = UDim2.fromOffset(22, 2),
						BackgroundColor3 = Color3.fromRGB(255,255,255)
					})
				else
					tween(box, TweenInfo.new(0.18), {BackgroundColor3 = self.Tab.Window.Theme.Card})
					tween(knob, TweenInfo.new(0.18), {
						Position = UDim2.fromOffset(2, 2),
						BackgroundColor3 = self.Tab.Window.Theme.SubText
					})
				end
				if not skipCallback and data.Callback then
					pcall(data.Callback, state)
				end
			end

			function comp:Set(v, skipCallback)
				if comp.Locked then return end
				state = not not v
				render(skipCallback)
			end
			function comp:Get() return state end
			function comp:SetText(v) lbl.Text = tostring(v) end
			function comp:Lock(v)
				comp.Locked = v
				root.AutoButtonColor = not v
				root.BackgroundTransparency = v and 0.25 or 0
			end

			root.MouseButton1Click:Connect(function()
				if comp.Locked then return end
				state = not state
				render(false)
			end)

			render(true)
			registerFlag(flag, comp)
			return baseAPI(comp, root)
		end

		function section:CreateSlider(data)
			data = data or {}
			local flag = data.Flag
			local min = data.Min or 0
			local max = data.Max or 100
			local value = clamp(data.Default or min, min, max)
			local rounding = data.Rounding or 0
			self.Tab.Window.Flags[flag] = value

			local root = create("Frame", {
				Size = UDim2.new(1, 0, 0, 58),
				BackgroundColor3 = self.Tab.Window.Theme.Panel2,
				BorderSizePixel = 0,
				Parent = holder
			})
			addCorner(root, UDim.new(0, 10))
			addStroke(root, self.Tab.Window.Theme.Stroke, 1, 0)

			local lbl = create("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(12, 8),
				Size = UDim2.new(1, -70, 0, 18),
				Text = data.Text or "Slider",
				Font = Enum.Font.GothamSemibold,
				TextColor3 = self.Tab.Window.Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = root
			})

			local valLbl = create("TextLabel", {
				BackgroundTransparency = 1,
				AnchorPoint = Vector2.new(1, 0),
				Position = UDim2.new(1, -12, 8),
				Size = UDim2.fromOffset(60, 18),
				Text = tostring(value),
				Font = Enum.Font.Gotham,
				TextColor3 = self.Tab.Window.Theme.SubText,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right,
				Parent = root
			})

			local bar = create("Frame", {
				Position = UDim2.fromOffset(12, 34),
				Size = UDim2.new(1, -24, 0, 10),
				BackgroundColor3 = self.Tab.Window.Theme.Card,
				BorderSizePixel = 0,
				Parent = root
			})
			addCorner(bar, UDim.new(1,0))

			local fill = create("Frame", {
				Size = UDim2.new(0, 0, 1, 0),
				BackgroundColor3 = self.Tab.Window.Theme.Accent,
				BorderSizePixel = 0,
				Parent = bar
			})
			addCorner(fill, UDim.new(1,0))
			addGradient(fill, self.Tab.Window.Theme.Accent, self.Tab.Window.Theme.Accent2, 0)

			local dragging = false
			local comp = {Root = root, Value = value, Locked = false}

			local function round(v)
				if rounding <= 0 then return math.floor(v + 0.5) end
				local mult = 10 ^ rounding
				return math.floor(v * mult + 0.5) / mult
			end

			local function render(skipCallback)
				local alpha = (value - min) / (max - min)
				alpha = clamp(alpha, 0, 1)
				fill.Size = UDim2.new(alpha, 0, 1, 0)
				valLbl.Text = tostring(value)
				self.Tab.Window.Flags[flag] = value
				comp.Value = value
				if not skipCallback and data.Callback then
					pcall(data.Callback, value)
				end
			end

			local function setFromX(x)
				local px = x - bar.AbsolutePosition.X
				local alpha = clamp(px / bar.AbsoluteSize.X, 0, 1)
				value = round(min + (max - min) * alpha)
				render(false)
			end

			function comp:Set(v, skipCallback)
				if comp.Locked then return end
				value = clamp(v, min, max)
				value = round(value)
				render(skipCallback)
			end
			function comp:Get() return value end
			function comp:SetText(v) lbl.Text = tostring(v) end
			function comp:Lock(v)
				comp.Locked = v
				root.BackgroundTransparency = v and 0.25 or 0
			end

			function comp:TweenValue(v, duration, style, direction)
				if comp.Locked then return end
				local start = value
				local goal = clamp(v, min, max)
				duration = duration or 0.5
				style = style or Enum.EasingStyle.Quad
				direction = direction or Enum.EasingDirection.Out

				local num = Instance.new("NumberValue")
				num.Value = start
				local tw = TweenService:Create(num, TweenInfo.new(duration, style, direction), {Value = goal})
				local conn
				conn = num:GetPropertyChangedSignal("Value"):Connect(function()
					value = round(num.Value)
					render(true)
					if data.Callback then
						pcall(data.Callback, value)
					end
				end)
				tw:Play()
				tw.Completed:Connect(function()
					if conn then conn:Disconnect() end
					num:Destroy()
				end)
			end

			bar.InputBegan:Connect(function(input)
				if comp.Locked then return end
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					setFromX(input.Position.X)
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					setFromX(input.Position.X)
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			render(true)
			registerFlag(flag, comp)
			return baseAPI(comp, root)
		end

