				local callback = opts.Callback or function() end

				local function updateToggle(skipCallback)
					if value then
						tween(ToggleBack, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							BackgroundColor3 = self.Tab.Window.Theme.Accent
						})
						tween(ToggleKnob, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							Position = UDim2.new(0, 24, 0, 2)
						})
					else
						tween(ToggleBack, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							BackgroundColor3 = self.Tab.Window.Theme.Surface3
						})
						tween(ToggleKnob, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							Position = UDim2.new(0, 2, 0, 2)
						})
					end

					if not skipCallback then
						pcall(callback, value)
					end
				end

				Frame.MouseButton1Click:Connect(function()
					if control.Locked then return end
					value = not value
					updateToggle(false)
				end)

				applyButtonHover(Frame, self.Tab.Window.Theme.Surface, self.Tab.Window.Theme.Surface2)

				control.Frame = Frame
				control.Button = Frame
				control.Label = Label
				control.Interactive = Frame

				function control:Set(state, skipCallback)
					value = state and true or false
					updateToggle(skipCallback)
				end

				function control:Get()
					return value
				end

				function control:SetText(text)
					Label.Text = tostring(text)
				end

				function control:SetCallback(fn)
					callback = fn or function() end
				end

				function control:UpdateTheme()
					updateToggle(true)
				end

				registerConfig(key, function()
					return value
				end, function(v)
					control:Set(v, true)
				end)

				updateToggle(true)

				table.insert(Section.Controls, control)
				table.insert(self.Tab.Window.RuntimeRegistry, control)
				return control
			end

			-- Slider
			function Section:CreateSlider(opts)
				opts = opts or {}
				local control = baseMethods(newControl("Slider"))

				local min = opts.Min or 0
				local max = opts.Max or 100
				local decimals = opts.Decimals or 0
				local value = clamp(opts.Default or min, min, max)
				local key = opts.Flag or opts.Key or opts.Name
				local callback = opts.Callback or function() end

				local Frame = create("Frame", {
					BackgroundColor3 = self.Tab.Window.Theme.Surface,
					Size = UDim2.new(1, 0, 0, 56),
					Parent = Holder
				})
				addCorner(Frame, 10)
				addStroke(Frame, self.Tab.Window.Theme.Border, 1, 0.25)

				local Label = create("TextLabel", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0, 8),
					Size = UDim2.new(1, -70, 0, 16),
					Text = opts.Name or "Slider",
					Font = Enum.Font.GothamMedium,
					TextSize = 13,
					TextColor3 = self.Tab.Window.Theme.Text,
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Frame
				})

				local ValueLabel = create("TextLabel", {
					BackgroundTransparency = 1,
					AnchorPoint = Vector2.new(1, 0),
					Position = UDim2.new(1, -12, 0, 8),
					Size = UDim2.new(0, 60, 0, 16),
					Text = tostring(value),
					Font = Enum.Font.Gotham,
					TextSize = 12,
					TextColor3 = self.Tab.Window.Theme.SubText,
					TextXAlignment = Enum.TextXAlignment.Right,
					Parent = Frame
				})

				local Bar = create("Frame", {
					BackgroundColor3 = self.Tab.Window.Theme.Surface3,
					Size = UDim2.new(1, -24, 0, 8),
					Position = UDim2.new(0, 12, 0, 34),
					Parent = Frame
				})
				addCorner(Bar, 999)

				local Fill = create("Frame", {
					BackgroundColor3 = self.Tab.Window.Theme.Accent,
					Size = UDim2.new(0, 0, 1, 0),
					Parent = Bar
				})
				addCorner(Fill, 999)

				local dragging = false

				local function updateVisual(skipCallback)
					local alpha = (value - min) / (max - min)
					Fill.Size = UDim2.new(alpha, 0, 1, 0)
					ValueLabel.Text = tostring(round(value, decimals))
					if not skipCallback then
						pcall(callback, round(value, decimals))
					end
				end

				local function setFromX(x, skipCallback)
					local rel = clamp((x - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
					local raw = min + (max - min) * rel
					value = round(raw, decimals)
					updateVisual(skipCallback)
				end

				Bar.InputBegan:Connect(function(input)
					if control.Locked then return end
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = true
						setFromX(input.Position.X, false)
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						setFromX(input.Position.X, false)
					end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = false
					end
				end)

				control.Frame = Frame
				control.Bar = Bar
				control.Fill = Fill
				control.Label = Label
				control.Interactive = Bar

				function control:Set(v, skipCallback)
					value = clamp(v, min, max)
					updateVisual(skipCallback)
				end

				function control:Get()
					return value
				end

				function control:SetText(text)
					Label.Text = tostring(text)
				end

				function control:SetCallback(fn)
					callback = fn or function() end
				end

				function control:UpdateTheme()
					Fill.BackgroundColor3 = self.Tab.Window.Theme.Accent
				end

				registerConfig(key, function()
					return value
				end, function(v)
					control:Set(v, true)
				end)

				updateVisual(true)

				table.insert(Section.Controls, control)
				table.insert(self.Tab.Window.RuntimeRegistry, control)
				return control
			end

