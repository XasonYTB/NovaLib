	local function refreshWindowFrames()
		Root.BackgroundColor3 = window.Theme.Background
		Header.BackgroundColor3 = window.Theme.Surface
		AccentLine.BackgroundColor3 = window.Theme.Accent
		Sidebar.BackgroundColor3 = window.Theme.Sidebar
		ContentBg.BackgroundColor3 = window.Theme.Background
		Title.TextColor3 = window.Theme.Text
		Subtitle.TextColor3 = window.Theme.SubText
		Shadow.ImageColor3 = window.Theme.Shadow
		Stroke(Root, window.Theme.Stroke, 1, 0)
	end

	window.ActiveTab = nil

	local function registerControl(key, control)
		if not key then return end
		window._registry[key] = control
	end

	function window:_SetActiveTab(tab)
		for _, t in ipairs(window.Tabs) do
			if t.Page then
				t.Page.Visible = false
			end
			if t.Button then
				Tween(t.Button, {BackgroundColor3 = window.Theme.Surface2}, 0.14)
				if t.Indicator then
					Tween(t.Indicator, {Size = UDim2.new(0, 4, 0, 0)}, 0.14)
				end
				if t.Text then
					t.Text.TextColor3 = window.Theme.SubText
				end
				if t.Icon then
					t.Icon.TextColor3 = window.Theme.SubText
				end
			end
		end

		window.ActiveTab = tab
		if tab and tab.Page then
			tab.Page.Visible = true
		end
		if tab and tab.Button then
			Tween(tab.Button, {BackgroundColor3 = window.Theme.Surface3}, 0.14)
			if tab.Indicator then
				Tween(tab.Indicator, {Size = UDim2.new(0, 4, 0, 22)}, 0.14)
			end
			if tab.Text then
				tab.Text.TextColor3 = window.Theme.Text
			end
			if tab.Icon then
				tab.Icon.TextColor3 = window.Theme.Accent
			end
		end
	end

	function window:ToggleVisible(force)
		if typeof(force) == "boolean" then
			window.Visible = force
		else
			window.Visible = not window.Visible
		end
		Root.Visible = window.Visible
		Shadow.Visible = window.Visible
		if window.CursorDot then
			window.CursorDot.Visible = window.Visible and window.CursorEnabled and not window.Mobile
		end
	end

	function window:SetMinimized(state)
		window.Minimized = state and true or false
		if window.Minimized then
			Body.Visible = false
			Tween(Root, {Size = UDim2.new(0, Root.AbsoluteSize.X, 0, 56)}, 0.22)
		else
			Body.Visible = true
			local targetSize = UDim2.new(0, window.Mobile and math.min(workspace.CurrentCamera.ViewportSize.X - 24, 420) or 520, 0, window.Mobile and math.min(workspace.CurrentCamera.ViewportSize.Y - 40, 620) or 400)
			Tween(Root, {Size = targetSize}, 0.22)
		end
	end

	function window:Destroy()
		for _, c in ipairs(window._connections) do
			pcall(function()
				c:Disconnect()
			end)
		end
		if window.CursorRenderName then
			pcall(function()
				RunService:UnbindFromRenderStep(window.CursorRenderName)
			end)
		end
		if ScreenGui then
			ScreenGui:Destroy()
		end
	end

