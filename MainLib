			BackgroundColor3 = opts.Color or self.Theme.Accent,
			Size = UDim2.new(0, 4, 1, 0),
			Parent = n
		})
		addCorner(bar, 12)

		local title = create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 14, 0, 10),
			Size = UDim2.new(1, -24, 0, 18),
			Font = Enum.Font.GothamBold,
