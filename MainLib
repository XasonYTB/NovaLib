				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = root
			})

			local arrow = create("TextLabel", {
				BackgroundTransparency = 1,
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -12, 0.5, 0),
				Size = UDim2.fromOffset(20, 20),
				Text = "▼",
				Font = Enum.Font.GothamBold,
				TextColor3 = self.Tab.Window.Theme.SubText,
				TextSize = 12,
				Parent = root
			})

			local listHolder = create("Frame", {
				Position = UDim2.fromOffset(8, 42),
				Size = UDim2.new(1, -16, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				BackgroundTransparency = 1,
				Parent = root
			})
			local optList = addList(listHolder, 6)

			local open = false
			local optionButtons = {}
			local comp = {Root = root, Options = options}

			local function rebuild()
				for _, c in ipairs(optionButtons) do
					if c then c:Destroy() end
				end
				optionButtons = {}
				for _, opt in ipairs(options) do
					local b = create("TextButton", {
						Size = UDim2.new(1, 0, 0, 30),
						BackgroundColor3 = self.Tab.Window.Theme.Card,
						BorderSizePixel = 0,
						Text = tostring(opt),
						Font = Enum.Font.Gotham,
						TextSize = 12,
						TextColor3 = self.Tab.Window.Theme.Text,
						AutoButtonColor = false,
						Parent = listHolder
					})
					addCorner(b, UDim.new(0, 8))
					addStroke(b, self.Tab.Window.Theme.Stroke, 1, 0)
					attachButtonFx(b, self.Tab.Window.Theme)
					b.MouseButton1Click:Connect(function()
						value = opt
						self.Tab.Window.Flags[flag] = value
						lbl.Text = (data.Text or "Dropdown") .. ": " .. tostring(value)
						if data.Callback then pcall(data.Callback, value) end
						open = false
						root.Size = UDim2.new(1, 0, 0, 42)
						arrow.Text = "▼"
					end)
					table.insert(optionButtons, b)
				end
			end

			function comp:Set(v, skipCallback)
				value = v
				self.Tab.Window.Flags[flag] = value
				lbl.Text = (data.Text or "Dropdown") .. ": " .. tostring(value)
				if not skipCallback and data.Callback then
					pcall(data.Callback, value)
				end
			end
			function comp:Get() return value end
			function comp:SetText(v)
				lbl.Text = tostring(v) .. ": " .. tostring(value)
			end
			function comp:SetOptions(newOptions)
				options = newOptions
				comp.Options = options
				rebuild()
			end

			rebuild()

			button.MouseButton1Click:Connect(function()
				open = not open
				root.Size = open and UDim2.new(1, 0, 0, 42 + listHolder.AbsoluteSize.Y + 8) or UDim2.new(1, 0, 0, 42)
				arrow.Text = open and "▲" or "▼"
			end)

			registerFlag(flag, comp)
			return baseAPI(comp, root)
		end

		function section:CreateMultiDropdown(data)
			data = data or {}
			local flag = data.Flag
			local options = data.Options or {}
			local selected = data.Default or {}
			self.Tab.Window.Flags[flag] = selected

			local root = create("Frame", {
				Size = UDim2.new(1, 0, 0, 42),
				ClipsDescendants = true,
				BackgroundColor3 = self.Tab.Window.Theme.Panel2,
				BorderSizePixel = 0,
				Parent = holder
			})
			addCorner(root, UDim.new(0, 10))
			addStroke(root, self.Tab.Window.Theme.Stroke, 1, 0)

			local button = create("TextButton", {
				Size = UDim2.new(1, 0, 0, 42),
				BackgroundTransparency = 1,
				Text = "",
				Parent = root
			})

			local function countSelected()
				local c = 0
				for _ in pairs(selected) do c += 1 end
				return c
			end

			local lbl = create("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(12, 0),
				Size = UDim2.new(1, -80, 0, 42),
				Text = (data.Text or "MultiDropdown") .. ": " .. tostring(countSelected()) .. " selected",
				Font = Enum.Font.GothamSemibold,
				TextColor3 = self.Tab.Window.Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = root
			})

			local arrow = create("TextLabel", {
				BackgroundTransparency = 1,
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -12, 0.5, 0),
				Size = UDim2.fromOffset(20, 20),
				Text = "▼",
				Font = Enum.Font.GothamBold,
				TextColor3 = self.Tab.Window.Theme.SubText,
				TextSize = 12,
				Parent = root
			})

			local listHolder = create("Frame", {
				Position = UDim2.fromOffset(8, 42),
				Size = UDim2.new(1, -16, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				BackgroundTransparency = 1,
				Parent = root
			})
			local optList = addList(listHolder, 6)

			local open = false
			local comp = {Root = root}

			local function refreshLabel()
				lbl.Text = (data.Text or "MultiDropdown") .. ": " .. tostring(countSelected()) .. " selected"
			end

			local function rebuild()
				listHolder:ClearAllChildren()
				addList(listHolder, 6)
				for _, opt in ipairs(options) do
					local active = selected[opt] == true
					local b = create("TextButton", {
						Size = UDim2.new(1, 0, 0, 30),
						BackgroundColor3 = active and self.Tab.Window.Theme.Accent or self.Tab.Window.Theme.Card,
						BorderSizePixel = 0,
						Text = tostring(opt),
						Font = Enum.Font.Gotham,
						TextSize = 12,
						TextColor3 = self.Tab.Window.Theme.Text,
						AutoButtonColor = false,
						Parent = listHolder
					})
					addCorner(b, UDim.new(0, 8))
					addStroke(b, self.Tab.Window.Theme.Stroke, 1, 0)
					b.MouseButton1Click:Connect(function()
						selected[opt] = not selected[opt]
						self.Tab.Window.Flags[flag] = selected
						rebuild()
						refreshLabel()
						if data.Callback then pcall(data.Callback, selected) end
					end)
				end
			end

			function comp:Set(tbl, skipCallback)
				selected = tbl or {}
				self.Tab.Window.Flags[flag] = selected
				rebuild()
				refreshLabel()
				if not skipCallback and data.Callback then
					pcall(data.Callback, selected)
				end
			end
			function comp:Get() return selected end
			function comp:SetOptions(newOptions)
				options = newOptions or {}
				rebuild()
			end
			function comp:SetText(v)
				lbl.Text = tostring(v) .. ": " .. tostring(countSelected()) .. " selected"
			end

			rebuild()

			button.MouseButton1Click:Connect(function()
				open = not open
				root.Size = open and UDim2.new(1, 0, 0, 42 + listHolder.AbsoluteSize.Y + 8) or UDim2.new(1, 0, 0, 42)
				arrow.Text = open and "▲" or "▼"
			end)

			registerFlag(flag, comp)
			return baseAPI(comp, root)
		end

		function section:CreateKeybind(data)
			data = data or {}
			local flag = data.Flag
			local key = data.Default or Enum.KeyCode.E
			self.Tab.Window.Flags[flag] = key.Name

			local root = create("TextButton", {
				Size = UDim2.new(1, 0, 0, 42),
				BackgroundColor3 = self.Tab.Window.Theme.Panel2,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
				Parent = holder
			})
			addCorner(root, UDim.new(0, 10))
			addStroke(root, self.Tab.Window.Theme.Stroke, 1, 0)

			local lbl = create("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(12, 0),
				Size = UDim2.new(1, -90, 1, 0),
				Text = data.Text or "Keybind",
				Font = Enum.Font.GothamSemibold,
				TextColor3 = self.Tab.Window.Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = root
			})

			local keyBtn = create("TextButton", {
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -12, 0.5, 0),
				Size = UDim2.fromOffset(68, 26),
				BackgroundColor3 = self.Tab.Window.Theme.Card,
				BorderSizePixel = 0,
				Text = key.Name,
				Font = Enum.Font.GothamSemibold,
				TextColor3 = self.Tab.Window.Theme.Text,
				TextSize = 12,
				AutoButtonColor = false,
				Parent = root
			})
			addCorner(keyBtn, UDim.new(0, 8))
			addStroke(keyBtn, self.Tab.Window.Theme.Stroke, 1, 0)

			local listening = false
			local comp = {Root = root}

			function comp:Set(v, skipCallback)
				key = v
				self.Tab.Window.Flags[flag] = key.Name
				keyBtn.Text = key.Name
				if not skipCallback and data.Callback then
					pcall(data.Callback, key)
				end
			end
			function comp:Get() return key end
			function comp:SetText(v) lbl.Text = tostring(v) end

			keyBtn.MouseButton1Click:Connect(function()
				listening = true
				keyBtn.Text = "..."
			end)

			table.insert(self.Tab.Window.ConnectionBag, UserInputService.InputBegan:Connect(function(input, gp)
				if gp then return end
				if listening and input.KeyCode ~= Enum.KeyCode.Unknown then
					listening = false
					key = input.KeyCode
					self.Tab.Window.Flags[flag] = key.Name
					keyBtn.Text = key.Name
					if data.Callback then pcall(data.Callback, key) end
					return
				end
				if input.KeyCode == key then
					if data.Pressed then
						pcall(data.Pressed, key)
					end
				end
			end))

			registerFlag(flag, comp)
			return baseAPI(comp, root)
		end

		table.insert(self.Sections, section)
		return section
	end

	table.insert(self.Tabs, tab)

	if not self.CurrentTab and not isSystem then
		tab:Show()
	elseif #self.Tabs == 1 then
		tab:Show()
	end

	return tab
end

function Nova:_buildSettingsPage()
	local tab = self.SettingsTab

	local general = tab:CreateSection("General")
	local configs = tab:CreateSection("Configs")
	local themeSec = tab:CreateSection("Theme")
	local cursorSec = tab:CreateSection("Cursor & Mouse")

	general:CreateParagraph("Nova Settings", "This tab is always built in. Save configs, theme the UI, manage cursor, and toggle first-person mouse unlock here.")

	local uiToggle = general:CreateKeybind({
		Text = "UI Toggle Key",
		Flag = "__nova_toggle_key",
		Default = self.ToggleKey,
		Callback = function(key)
			self.ToggleKey = key
		end
	})

	local cfgName = configs:CreateTextbox({
		Text = "Config Name",
		Flag = "__nova_cfg_name",
		Default = self:GetAutoConfigName(),
		Placeholder = "Config name..."
	})

	configs:CreateButton({
		Text = "Save Config",
		Callback = function()
			local ok, msg = self:SaveConfig(cfgName:Get())
			self:Notify({
				Title = ok and "Config Saved" or "Config Error",
				Content = tostring(msg),
				Time = 3
			})
		end
	})

	local configDropdown
	configDropdown = configs:CreateDropdown({
		Text = "Saved Configs",
		Flag = "__nova_cfg_list",
		Options = self:GetConfigs(),
		Default = (self:GetConfigs()[1] or "None"),
		Callback = function() end
	})

	configs:CreateButton({
		Text = "Refresh Config List",
		Callback = function()
			configDropdown:SetOptions(self:GetConfigs())
			self:Notify({
				Title = "Configs",
				Content = "Config list refreshed.",
				Time = 2
			})
		end
	})

	configs:CreateButton({
		Text = "Load Selected Config",
		Callback = function()
			local name = configDropdown:Get()
			if name and name ~= "None" then
				local ok, msg = self:LoadConfig(name)
				self:Notify({
					Title = ok and "Config Loaded" or "Config Error",
					Content = tostring(msg),
					Time = 3
				})
			end
		end
	})

	configs:CreateButton({
		Text = "Delete Selected Config",
		Callback = function()
			local name = configDropdown:Get()
			if name and name ~= "None" then
				local ok, msg = self:DeleteConfig(name)
				self:Notify({
					Title = ok and "Config Deleted" or "Config Error",
					Content = tostring(msg),
					Time = 3
				})
				configDropdown:SetOptions(self:GetConfigs())
			end
		end
	})

	themeSec:CreateDropdown({
		Text = "Preset Theme",
		Flag = "__nova_theme",
		Options = {"Default", "Midnight"},
		Default = self.ThemeName,
		Callback = function(v)
			self:SetTheme(v)
		end
	})

	local accentR = themeSec:CreateSlider({
		Text = "Accent R",
		Flag = "__nova_accent_r",
		Min = 0,
		Max = 255,
		Default = math.floor(self.Theme.Accent.R * 255),
		Callback = function()
			self.Theme.Accent = Color3.fromRGB(accentR:Get(), accentG:Get(), accentB:Get())
		end
	})
	local accentG = themeSec:CreateSlider({
		Text = "Accent G",
		Flag = "__nova_accent_g",
		Min = 0,
		Max = 255,
		Default = math.floor(self.Theme.Accent.G * 255),
		Callback = function()
			self.Theme.Accent = Color3.fromRGB(accentR:Get(), accentG:Get(), accentB:Get())
		end
	})
	local accentB = themeSec:CreateSlider({
		Text = "Accent B",
		Flag = "__nova_accent_b",
		Min = 0,
		Max = 255,
		Default = math.floor(self.Theme.Accent.B * 255),
		Callback = function()
			self.Theme.Accent = Color3.fromRGB(accentR:Get(), accentG:Get(), accentB:Get())
		end
	})

	cursorSec:CreateToggle({
		Text = "Enable Dot Cursor",
		Flag = "__nova_cursor_enabled",
		Default = true,
		Callback = function(v)
			self.CursorEnabled = v
		end
	})

	local curR = cursorSec:CreateSlider({
		Text = "Cursor R",
		Flag = "__nova_cursor_r",
		Min = 0,
		Max = 255,
		Default = math.floor(self.Theme.Cursor.R * 255),
		Callback = function()
			local c = Color3.fromRGB(curR:Get(), curG:Get(), curB:Get())
			self.Theme.Cursor = c
			self.CursorDot.BackgroundColor3 = c
			if self.CursorDot:FindFirstChild("Glow") then
				self.CursorDot.Glow.BackgroundColor3 = c
			end
		end
	})
	local curG = cursorSec:CreateSlider({
		Text = "Cursor G",
		Flag = "__nova_cursor_g",
		Min = 0,
		Max = 255,
		Default = math.floor(self.Theme.Cursor.G * 255),
		Callback = function()
			local c = Color3.fromRGB(curR:Get(), curG:Get(), curB:Get())
			self.Theme.Cursor = c
			self.CursorDot.BackgroundColor3 = c
			if self.CursorDot:FindFirstChild("Glow") then
				self.CursorDot.Glow.BackgroundColor3 = c
			end
		end
	})
	local curB = cursorSec:CreateSlider({
		Text = "Cursor B",
		Flag = "__nova_cursor_b",
		Min = 0,
		Max = 255,
		Default = math.floor(self.Theme.Cursor.B * 255),
		Callback = function()
			local c = Color3.fromRGB(curR:Get(), curG:Get(), curB:Get())
			self.Theme.Cursor = c
			self.CursorDot.BackgroundColor3 = c
			if self.CursorDot:FindFirstChild("Glow") then
				self.CursorDot.Glow.BackgroundColor3 = c
			end
		end
	})

	cursorSec:CreateToggle({
		Text = "Modal Mouse Unlock",
		Flag = "__nova_modal",
		Default = false,
		Callback = function(v)
			self.ModalEnabled = v
			self:_applyModal()
		end
	})
end

function Nova:GetFlag(flag)
	return self.Flags[flag]
end

function Nova:SetFlag(flag, value, skipCallback)
	self.Flags[flag] = value
	local comp = self.Components[flag]
	if comp and comp.Set then
		comp:Set(value, skipCallback)
	end
end

function Nova:Destroy()
	for _, c in ipairs(self.ConnectionBag) do
		pcall(function() c:Disconnect() end)
	end
	if self.ScreenGui then
		self.ScreenGui:Destroy()
	end
end

