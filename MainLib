			local function makeBaseControl(typeName)
				local control = {
					Type = typeName,
					Frame = nil,
					Button = nil,
					Label = nil,
					Destroyed = false,
					Visible = true,
					Locked = false,
					Connections = {}
				}

				function control:Hide()
					if self.Frame then self.Frame.Visible = false end
					self.Visible = false
				end

				function control:Show()
					if self.Frame then self.Frame.Visible = true end
					self.Visible = true
				end

				function control:SetVisible(v)
					if v then self:Show() else self:Hide() end
				end

				function control:Destroy()
					for _, conn in ipairs(self.Connections) do
						pcall(function() conn:Disconnect() end)
					end
					if self.Frame then self.Frame:Destroy() end
					self.Destroyed = true
				end

				function control:Lock(v)
					self.Locked = v and true or false
				end

				return control
			end

