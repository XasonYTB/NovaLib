		function section:CreateToggle(data)
			data = data or {}
			local flag = data.Flag
			local state = data.Default or false
			self.Tab.Window.Flags[flag] = state

			local root = create("TextButton", {
				Size = UDim2.new(1, 0, 0, 42),
				BackgroundColor3 = self.Tab.Window.Theme.Panel2,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
				Parent = holder
			})
			addCorner(root, UDim.new(0, 10))
			addStroke(root, self.Tab.Window.Theme.Stroke, 1, 0)

			local lbl = create("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(12, 0),
				Size = UDim2.new(1, -70, 1, 0),
				Font = Enum.Font.GothamSemibold,
				Text = data.Text or "Toggle",
				TextColor3 = self.Tab.Window.Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = root
			})

			local box = create("Frame", {
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -12, 0.5, 0),
