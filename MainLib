			TextSize = 14,
			TextColor3 = self.Theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = n
		})

		local content = create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 14, 0, 30),
			Size = UDim2.new(1, -24, 1, -36),
			Font = Enum.Font.Gotham,
			TextWrapped = true,
