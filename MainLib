					Size = UDim2.new(1, -20, 0, 126),
					BackgroundTransparency = 1
				})
				List(holder, 8, false)

				local function fire()
					local c = Color3.fromRGB(r, g, b)
					preview.BackgroundColor3 = c
					safeCall(callback, c)
				end

				local function makeRGBRow(channel, initial, setValue)
					local row = Create("Frame", {
						Parent = holder,
						Size = UDim2.new(1, 0, 0, 34),
						BackgroundTransparency = 1
					})

					local lbl = Create("TextLabel", {
						Parent = row,
						BackgroundTransparency = 1,
						Position = UDim2.new(0, 0, 0, 0),
						Size = UDim2.new(0, 18, 1, 0),
						Text = channel,
						Font = Enum.Font.GothamBold,
						TextSize = 12,
						TextColor3 = window.Theme.Text
					})

					local valLbl = Create("TextLabel", {
						Parent = row,
						BackgroundTransparency = 1,
						AnchorPoint = Vector2.new(1, 0),
						Position = UDim2.new(1, 0, 0, 0),
						Size = UDim2.new(0, 36, 1, 0),
						Text = tostring(initial),
						Font = Enum.Font.Gotham,
						TextSize = 12,
						TextColor3 = window.Theme.SubText,
						TextXAlignment = Enum.TextXAlignment.Right
					})

					local bar = Create("Frame", {
						Parent = row,
						Position = UDim2.new(0, 26, 0.5, 0),
						AnchorPoint = Vector2.new(0, 0.5),
						Size = UDim2.new(1, -70, 0, 8),
						BackgroundColor3 = window.Theme.Surface,
						BorderSizePixel = 0
					})
					Corner(bar, 8)

					local fill = Create("Frame", {
						Parent = bar,
						Size = UDim2.new(initial / 255, 0, 1, 0),
						BackgroundColor3 = window.Theme.Accent,
						BorderSizePixel = 0
					})
					Corner(fill, 8)

					local dragging = false

					local function setFromX(x)
						local pct = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
						local v = math.floor(pct * 255 + 0.5)
						fill.Size = UDim2.new(pct, 0, 1, 0)
						valLbl.Text = tostring(v)
						setValue(v)
						fire()
					end

					bar.InputBegan:Connect(function(input)
						if control.Locked then return end
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							dragging = true
							setFromX(input.Position.X)
						end
					end)

					trackConnection(UserInputService.InputChanged:Connect(function(input)
						if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
							setFromX(input.Position.X)
						end
					end))

					trackConnection(UserInputService.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							dragging = false
						end
					end))
				end

				makeRGBRow("R", r, function(v) r = v end)
				makeRGBRow("G", g, function(v) g = v end)
				makeRGBRow("B", b, function(v) b = v end)

				control.Frame = f
				control.Label = titleLbl
				control.Preview = preview
				control.Interactive = f
				function control:Get()
					return {r, g, b}
				end
				function control:Set(v, skip)
					local c = ArrayToColor(v)
					r = math.floor(c.R * 255)
					g = math.floor(c.G * 255)
					b = math.floor(c.B * 255)
					preview.BackgroundColor3 = c
					if not skip then
						safeCall(callback, c)
					end
				end
				function control:SetColor(c)
					control:Set(c)
				end
				function control:SetText(text)
					titleLbl.Text = tostring(text)
				end
				function control:SetCallback(fn)
					callback = fn or function() end
				end

				window:_RegisterControl(key, control)
				table.insert(section.Controls, control)
				return control
			end

			function section:AddSearchBox(data)
				data = data or {}
				local control = section:AddTextbox({
					Name = data.Name or "Search",
					Placeholder = data.Placeholder or "Search this section...",
					Callback = function(text)
						local q = string.lower(text or "")
						for _, item in ipairs(section._searchItems) do
							local show = q == "" or string.find(string.lower(item.Name or ""), q, 1, true)
							for _, ref in ipairs(item.Refs or {}) do
								if ref and ref.Visible ~= nil then
									ref.Visible = show
								end
							end
						end
						if data.Callback then
							data.Callback(text)
						end
					end
				})
				return control
			end

			tab.Sections[#tab.Sections + 1] = section
			return section
		end

		table.insert(window.Tabs, tab)
		if not window.ActiveTab or window.ActiveTab.Name == "Settings" or tab.Name == "Settings" then
			window:_SetActiveTab(tab)
		end

		return tab
	end

	function window:BuildSettingsTab()
		if window.SettingsBuilt then
			return window.SettingsTab
		end
		window.SettingsBuilt = true

		local Settings = window:CreateTab("Settings", "⚙")
		window.SettingsTab = Settings

		local Appearance = Settings:CreateSection("Appearance")
		local Configs = Settings:CreateSection("Configs")
		local Controls = Settings:CreateSection("Controls")

		local AccentPicker = Appearance:AddColorPicker({
			Name = "Accent Color",
			Default = window.Theme.Accent,
			Flag = "Settings_Accent",
			Callback = function(c)
				window.Theme.Accent = c
				window:RefreshTheme()
			end
		})

		local CursorToggle = Appearance:AddToggle({
			Name = "Custom Cursor",
			Default = false,
			Flag = "Settings_CursorToggle",
			Callback = function(v)
				window:SetCursor({
					Enabled = v,
					Color = window.Theme.Cursor,
					Size = 6
				})
			end
		})

		local CursorPicker = Appearance:AddColorPicker({
			Name = "Cursor Color",
			Default = window.Theme.Cursor,
			Flag = "Settings_CursorColor",
			Callback = function(c)
				window.Theme.Cursor = c
				window:RefreshTheme()
				if window.CursorDot then
					window.CursorDot.BackgroundColor3 = c
				end
			end
		})

		Appearance:AddButton({
			Name = "Apply Theme",
			Callback = function()
				window:RefreshTheme()
			end
		})

		local ConfigName = Configs:AddTextbox({
			Name = "Config Name",
			Default = window.DefaultConfigName,
			Placeholder = window.DefaultConfigName,
			Flag = "Settings_ConfigName"
		})

		local ConfigList = Configs:AddDropdown({
			Name = "Saved Configs",
			Options = window:GetConfigs(),
			Flag = "Settings_ConfigList",
			Callback = function(v)
				if v then
					window:LoadConfig(v)
				end
			end
		})

		Configs:AddButton({
			Name = "Save Config",
			Callback = function()
				window:SaveConfig(ConfigName:Get())
				ConfigList:SetOptions(window:GetConfigs())
			end
		})

		Configs:AddButton({
			Name = "Load Config",
			Callback = function()
				window:LoadConfig(ConfigName:Get())
			end
		})

		Configs:AddButton({
			Name = "Delete Config",
			Callback = function()
				window:DeleteConfig(ConfigName:Get())
				ConfigList:SetOptions(window:GetConfigs())
			end
		})

		Configs:AddButton({
			Name = "Refresh Config List",
			Callback = function()
				ConfigList:SetOptions(window:GetConfigs())
			end
		})

		local ToggleBind = Controls:AddKeybind({
			Name = "UI Toggle Key",
			Default = window.ToggleKeybind,
			Flag = "Settings_ToggleKey",
			Changed = function(k)
				window.ToggleKeybind = k
			end,
			Callback = function()
				window:ToggleVisible()
			end
		})

		Controls:AddButton({
			Name = "Toggle Modal Mouse",
			Callback = function()
				window:SetModal(not window.ModalEnabled)
			end
		})

		Controls:AddButton({
			Name = "Minimize Window",
			Callback = function()
				window:SetMinimized(not window.Minimized)
			end
		})

		Controls:AddButton({
			Name = "Hide / Show Window",
			Callback = function()
				window:ToggleVisible()
			end
		})

		Controls:AddButton({
			Name = "Enable Cursor",
			Callback = function()
				CursorToggle:Set(true)
			end
		})

		window:RefreshTheme()
		return Settings
	end

	trackConnection(UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == window.ToggleKeybind then
			window:ToggleVisible()
		end
	end))

	window:BuildSettingsTab()

	window:SetCursor({
		Enabled = config.CustomCursor or false,
		Color = window.Theme.Cursor,
		Size = 6
	})

	if config.Modal then
		window:SetModal(true)
	end

	window:Notify({
		Title = "NovaUI Loaded",
		Content = window.Title .. " is ready.",
		Color = window.Theme.Accent,
		Duration = 3
	})

	function window:CreateNotification(title, content, color, duration)
		window:Notify({
			Title = title,
			Content = content,
			Color = color,
			Duration = duration
		})
	end

	return window
end

return NovaUI
