	--// Toggle UI
	function Window:ToggleVisible(force)
		if typeof(force) == "boolean" then
			self.IsHidden = not force
		else
			self.IsHidden = not self.IsHidden
		end
		Main.Visible = not self.IsHidden
	end

	--// Minimize
	function Window:SetMinimized(state)
		self.IsMinimized = state

		if state then
			tween(Main, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = UDim2.new(Main.Size.X.Scale, Main.Size.X.Offset, 0, 56)
			})
			Body.Visible = false
		else
			Body.Visible = true
			local targetSize = self.Mobile and UDim2.new(0.92, 0, 0.78, 0) or (options.Size or UDim2.new(0, 760, 0, 470))
			tween(Main, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = targetSize
			})
		end
	end

